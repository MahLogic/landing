                </div>
            </div>
            <ul class="hidden md:flex items-center gap-9 list-none m-0 p-0">
                {
                    navLinks.map(([href, lbl]) => (
                        <li>
                            <a
                                href={href}
                                class="f-mono c-muted hover-white-text transition-c nav-link"
                            >
                                {lbl}
                            </a>
                        </li>
                    ))
                }
                <li>
                    <a
                        href="#contact"
                        class="f-mono c-gold nav-pill nav-cta-link px-5 py-2"
                        data-ph-capture="cta_click"
                        data-ph-label="nav_primary"
                    >
                        Book a Consultation
                    </a>
                </li>
            </ul>
        </nav>
        <main>
            <!-- ── HERO ────────────────────────────────────────────────────────────────── -->
            <section
                class="relative min-h-screen flex items-center bg-navy grid-texture overflow-hidden px-6 md:px-16"
            >
                <div
                    class="absolute -top-48 -right-48 w-140 h-140 rounded-full glow-gold pointer-events-none"
                >
                </div>
                <div class="relative z-10 max-w-5xl mx-auto w-full pt-32 pb-24">
                    <div class="a1 flex items-center gap-4 mb-8">
                        <span class="block w-8 h-px bg-gold"></span>
                        <span class="f-mono c-gold hero-eyebrow"
                            >Custom Software Engineering In Africa</span
                        >
                    </div>

                    <h1
                        class="a2 f-display c-white font-light leading-none mb-8 hero-headline"
                    >
                        Systems built for<br /><em class="c-gold"
                            >serious businesses.</em
                        >
                    </h1>

                    <p
                        class="a3 c-muted font-light leading-loose mb-12 max-w-xl hero-body"
                    >
                        MahLogic Africa designs and builds custom software for
                        businesses that require more than off-the-shelf tools
                        can offer. We work directly with founders and operators
                        to build internal systems, platforms, and applications
                        that are precise, maintainable, and built to last.
                    </p>

                    <div class="a4 flex flex-wrap items-center gap-5">
                        <a
                            href="#contact"
                            class="bg-gold f-mono btn-primary"
                            data-ph-capture="cta_click"
                            data-ph-label="hero_primary">Book a Consultation</a
                        >
                        <a
                            href="#what-we-build"
                            class="f-mono c-muted hover-white-text transition-c btn-ghost inline-flex items-center gap-2"
                        >
                            See what we build -
                        </a>
                    </div>

                    <div
                        class="a5 mt-20 pt-8 f-display c-muted italic font-light max-w-lg leading-relaxed hero-quote"
                    >
                        "We do not build fast. We build correctly. There is a
                        meaningful difference."
                    </div>
                </div>
            </section>

            <!-- ── WHAT WE BUILD ────────────────────────────────────────────────────────── -->
            <section id="what-we-build" class="bg-navy px-6 md:px-16 py-28">
                <div class="max-w-5xl mx-auto">
                    <p class="f-mono c-gold mb-5 section-label">
                        Custom Software Development Services
                    </p>
                    <h2
                        class="f-display c-white font-light leading-tight section-title mb-4"
                    >
                        Custom systems. No templates.<br />No compromises.
                    </h2>
                    <p
                        class="c-muted font-light leading-loose max-w-lg mb-16 build-desc"
                    >
                        Every system we deliver is designed for a specific
                        business context. We do not adapt existing software — we
                        architect and build from the ground up, with your
                        operational requirements as the specification.
                    </p>
                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 bg-gap gap-1px"
                    >
                        {
                            builds.map((b) => (
                                <div class="bg-navymid hover-navy transition-bg p-10">
                                    <p class="f-mono c-gold mb-5 build-number">
                                        {b.n}
                                    </p>
                                    <h3 class="f-display c-white font-normal mb-3 build-title">
                                        {b.title}
                                    </h3>
                                    <p class="c-muted font-light leading-loose build-desc">
                                        {b.desc}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </section>

            <!-- ── APPROACH ─────────────────────────────────────────────────────────────── -->
            <section id="approach" class="bg-navymid px-6 md:px-16 py-28">
                <div class="max-w-5xl mx-auto">
                    <p class="f-mono c-gold mb-5 section-label">Our Approach</p>
                    <h2
                        class="f-display c-white font-light leading-tight section-title mb-10"
                    >
                        Engineered, not improvised.
                    </h2>
                    <div
                        class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24"
                    >
                        <!-- Steps -->
                        <div>
                            <p
                                class="c-muted font-light leading-loose mb-10 step-desc"
                            >
                                We follow a structured process because the
                                quality of a software system is determined long
                                before the first line of code. Clarity precedes
                                construction.
                            </p>
                            {
                                steps.map((s) => (
                                    <div class="flex gap-6 py-7 step-row">
                                        <span class="f-mono c-gold mt-1 shrink-0 step-number">
                                            {s.n}
                                        </span>
                                        <div>
                                            <h3 class="f-display c-white font-normal mb-2 step-title">
                                                {s.title}
                                            </h3>
                                            <p class="c-muted font-light leading-loose step-desc">
                                                {s.desc}
                                            </p>
                                        </div>
                                    </div>
                                ))
                            }
                        </div>

                        <!-- Principles -->
                        <div class="pt-1">
                            <p class="f-mono c-gold mb-8 principles-label">
                                How We Think
                            </p>
                            {
                                principles.map((p) => (
                                    <div class="pl-8 mb-10 principle-block">
                                        <h4 class="f-display c-white font-normal mb-2 principle-title">
                                            {p.title}
                                        </h4>
                                        <p class="c-muted font-light leading-loose principle-desc">
                                            {p.desc}
                                        </p>
                                    </div>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </section>

            <!-- ── HOW WE WORK ──────────────────────────────────────────────────────────── -->
            <section id="how-we-work" class="bg-navy px-6 md:px-16 py-28">
                <div class="max-w-5xl mx-auto">
                    <p class="f-mono c-gold mb-5 section-label">How We Work</p>
                    <h2
                        class="f-display c-white font-light leading-tight section-title mb-16"
                    >
                        Direct. Transparent. Deliberate.
                    </h2>
                    <div
                        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 bg-gap gap-1px"
                    >
                        {
                            howCards.map((h) => (
                                <div class="bg-navy hover-navy transition-bg p-10">
                                    <p class="f-mono c-gold mb-6 how-icon">
                                        {h.icon}
                                    </p>
                                    <h3 class="f-display c-white font-normal mb-3 how-title">
                                        {h.title}
                                    </h3>
                                    <p class="c-muted font-light leading-loose how-desc">
                                        {h.desc}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </section>

            <!-- ── TECHNOLOGY ───────────────────────────────────────────────────────────── -->
            <section id="technology" class="bg-navymid px-6 md:px-16 py-28">
                <div class="max-w-5xl mx-auto">
                    <p class="f-mono c-gold mb-5 section-label">
                        Modern Engineering Stack:
                    </p>
                    <h2
                        class="f-display c-white font-light leading-tight section-title mb-10"
                    >
                        A precise and deliberate stack.
                    </h2>
                    <div
                        class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24"
                    >
                        <div>
                            <p
                                class="c-muted font-light leading-loose mb-8 tech-body"
                            >
                                We do not chase frameworks. We use a focused,
                                well-understood technology stack that we build
                                with confidence and maintain with clarity. Each
                                choice is intentional.
                            </p>
                            <div class="p-8 tech-quote-block">
                                <p
                                    class="f-display c-muted italic font-light leading-loose tech-quote-text"
                                >
                                    "A good technology choice is one that
                                    reduces complexity over time, not one that
                                    demonstrates sophistication. Our stack
                                    reflects this."
                                </p>
                            </div>
                            <p
                                class="c-muted font-light leading-loose mt-6 f-display italic tech-note"
                            >
                                Non-technical clients do not need to understand
                                these choices — only that they are sound,
                                proven, and well-supported.
                            </p>
                        </div>

                        <div>
                            {
                                techStack.map((t) => (
                                    <div class="flex items-center justify-between py-4 tech-row">
