            property="og:title"
            content="MahLogic Africa | Custom Software Development Agency"
        />
        <meta
            property="og:description"
            content="Custom web applications, internal business systems, dashboards, and operational platforms built with modern engineering standards."
        />
        <meta property="og:url" content="https://mahlogic.africa" />
        <meta property="og:image" content="/og-image.jpg" />

        <meta name="twitter:card" content="summary_large_image" />
