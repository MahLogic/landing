            name="twitter:title"
            content="MahLogic Africa | Custom Software Development Agency"
        />
        <meta
            name="twitter:description"
            content="We build modern web applications, internal systems, dashboards, and secure client platforms."
        />
        <meta name="twitter:image" content="/og-image.jpg" />
        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "ProfessionalService",
                "name": "MahLogic Africa",
                "url": "https://mahlogic.africa",
                "logo": "https://mahlogic.africa/logo.png",
                "description": "Custom software engineering studio building bespoke web-based systems for business operations, including internal platforms, dashboards, and client portals.",
                "email": "hello@mahlogic.africa",
                "address": {
                    "@type": "PostalAddress",
                    "addressCountry": "South Africa",
                    "addressRegion": "Gauteng",
                    "addressLocality": "Randburg",
                    "addressSubLocality": "Ferndale"
                },
                "areaServed": [
                    {
                        "@type": "Place",
                        "name": "Africa"
                    },
                    {
                        "@type": "Place",
                        "name": "Worldwide"
                    }
                ],
                "foundingLocation": {
                    "@type": "Country",
                    "name": "South Africa"
                },
                "serviceType": [
                    "Internal business systems",
                    "Operational dashboards",
                    "Client portals",
                    "Administrative platforms",
                    "Workflow automation systems",
                    "High-performance web applications",
                    "Codebase review and assessment",
                    "Architecture refactoring",
                    "Security hardening for software systems"
                ],
                "knowsAbout": [
                    "Next.js",
