            document.addEventListener("click", (e) => {
                const el = e.target?.closest?.("[data-ph-capture]");
                if (!el || !window.posthog) return;
                window.posthog.capture(el.getAttribute("data-ph-capture"), {
                    label: el.getAttribute("data-ph-label") || undefined,
                    href: el.getAttribute("href") || undefined,
                });
            });
        </script>
        <script is:inline>
            (function () {
                const marks = new Set();
                const steps = [25, 50, 75, 90];
                function onScroll() {
                    const h = document.documentElement;
                    const pct = Math.round(
                        (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100,
                    );
                    steps.forEach((s) => {
                        if (pct >= s && !marks.has(s) && window.posthog) {
                            marks.add(s);
                            window.posthog.capture("scroll_depth", {
                                percent: s,
                            });
                        }
                    });
                }
                window.addEventListener("scroll", onScroll, { passive: true });
            })();
        </script>
